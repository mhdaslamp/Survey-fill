{
  "manifest_version": 3,
  "name": "ETLAB Survey Automator",
  "version": "1.0",
  "description": "Automate ETLAB feedback surveys with one click.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.etlab.in/*", "http://localhost/*", "file://*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  }
}
